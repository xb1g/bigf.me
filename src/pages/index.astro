---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Notebook from '../components/Notebook.astro';
import Gallery from '../components/Gallery.astro';
---

<Layout title="bigf.me • Bunyasit Fang">
  <main class="canvas-viewport canvas-bg relative select-none" style="touch-action: none; overscroll-behavior: none;" id="viewport">
    
    <!-- Canvas Surface -->
    <div id="canvas" class="canvas-surface transition-none">
      
      <!-- Coordinate Origin Marker (hidden by default, useful for debug or aesthetics) -->
      <div class="absolute left-0 top-0 w-4 h-4 -ml-2 -mt-2 border border-[#a09e99]/30 rounded-full opacity-50 flex items-center justify-center pointer-events-none">
        <div class="w-1 h-1 bg-[#a09e99] rounded-full"></div>
      </div>

      <!-- Item 1: Terminal -->
      <div class="absolute top-0 left-0 -translate-x-1/2 -translate-y-1/2 w-[90vw] md:w-[70vw] max-w-7xl h-[85vh] z-20 canvas-item group">
        <div class="absolute -top-8 left-0 text-[#a09e99] font-mono text-xs opacity-50 uppercase tracking-widest pointer-events-none">Workspace 01 : Engineering</div>
        <div class="w-full h-full shadow-[0_30px_80px_rgba(0,0,0,0.6)] rounded-[3rem] transition-transform duration-300 group-hover:scale-[1.01]">
          <Terminal />
        </div>
      </div>

      <!-- Item 2: Notebook -->
      <div class="absolute top-0 left-[1200px] -translate-x-1/2 -translate-y-1/2 w-[90vw] md:w-[70vw] max-w-5xl h-[80vh] z-10 canvas-item group">
         <div class="absolute -top-8 left-0 text-[#a09e99] font-mono text-xs opacity-50 uppercase tracking-widest pointer-events-none">Workspace 02 : Thoughts</div>
        <div class="w-full h-full transition-transform duration-300 group-hover:scale-[1.01]">
          <Notebook />
        </div>
      </div>

      <!-- Item 3: Gallery -->
      <div class="absolute top-0 left-[2400px] -translate-x-1/2 -translate-y-1/2 w-[90vw] md:w-[70vw] max-w-5xl h-[80vh] z-10 canvas-item group">
         <div class="absolute -top-8 left-0 text-[#a09e99] font-mono text-xs opacity-50 uppercase tracking-widest pointer-events-none">Workspace 03 : Gallery</div>
        <div class="w-full h-full transition-transform duration-300 group-hover:scale-[1.01]">
          <Gallery />
        </div>
      </div>

    </div>

    <!-- UI Overlay Controls / Navigation -->
    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 z-50 w-[90vw] md:w-auto">
      
      <!-- Mobile Quick Command Bar (Visible on small screens or anywhere) -->
      <div class="w-full md:hidden bg-[#0a0a0f]/80 backdrop-blur-xl border border-[#2a2a3f]/50 rounded-2xl px-3 py-2 flex items-center gap-2 overflow-x-auto scrollbar-hide shadow-xl">
        <button class="flex-shrink-0 w-8 h-8 rounded-full bg-[#ff6b9d]/10 border border-[#ff6b9d]/30 flex items-center justify-center text-[#ff6b9d]" title="Quick Commands">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </button>
        <div class="w-[1px] h-4 bg-[#2a2a3f] mx-1"></div>
        <button class="quick-cmd-btn px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-white/5 border border-white/10 text-white/70" data-cmd="highlights">Highlights</button>
        <button class="quick-cmd-btn px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-white/5 border border-white/10 text-white/70" data-cmd="ls">List</button>
        <button class="quick-cmd-btn px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-white/5 border border-white/10 text-white/70" data-cmd="cat life">Life</button>
        <button class="quick-cmd-btn px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-[#a78bfa]/10 border border-[#a78bfa]/30 text-[#a78bfa]" data-cmd="ai ">AI</button>
      </div>

      <!-- Main Navigation Bar -->
      <div class="bg-[#fdfcf8]/90 backdrop-blur-md border border-[#d0cdc5] shadow-[0_5px_15px_rgba(0,0,0,0.05)] rounded-full px-4 py-2 flex items-center gap-4">
        <button class="text-[#8c8577] hover:text-[#2c2c2c] transition-colors p-1" id="btn-home" title="Go to Terminal">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </button>
        <div class="w-[1px] h-4 bg-[#e8e6e1]"></div>
        <button class="text-[#8c8577] hover:text-[#2c2c2c] transition-colors p-1" id="btn-notebook" title="Go to Notebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        </button>
        <div class="w-[1px] h-4 bg-[#e8e6e1]"></div>
        <button class="text-[#8c8577] hover:text-[#2c2c2c] transition-colors p-1" id="btn-gallery" title="Go to Gallery">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </button>
        <div class="w-[1px] h-4 bg-[#e8e6e1] hidden md:block"></div>
        <button class="text-[#8c8577] hover:text-[#2c2c2c] transition-colors items-center gap-1 hidden md:flex" id="btn-zoom-out" title="Overview">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>
      </div>
    </div>

    <!-- Instructions Overlay -->
    <div class="fixed top-6 right-6 bg-[#fdfcf8]/90 backdrop-blur-md border border-[#d0cdc5] shadow-[0_5px_15px_rgba(0,0,0,0.05)] rounded-lg p-3 text-xs text-[#8c8577] font-sans z-50 pointer-events-none opacity-80">
      <div class="font-bold text-[#5a5955] mb-1 tracking-wider uppercase text-[9px]">Controls</div>
      <div><span class="inline-block bg-[#e8e6e1] px-1 rounded border border-[#d0cdc5] text-[#2c2c2c]">Space</span> + Drag to pan</div>
      <div class="mt-1"><span class="inline-block bg-[#e8e6e1] px-1 rounded border border-[#d0cdc5] text-[#2c2c2c]">Scroll</span> to pan / zoom</div>
    </div>

    <!-- Custom Cursor Elements -->
    <div id="cursor-dot" class="hidden md:block"></div>
    <div id="cursor-outline" class="hidden md:block"></div>

  </main>
</Layout>

<style>
  .canvas-item {
    /* Prevent grabbing canvas when interacting inside items unless space is down */
    cursor: auto; 
  }
  .is-panning {
    cursor: grabbing !important;
  }
  .is-panning .canvas-item {
    pointer-events: none; /* Disable interaction with children while panning */
  }
  /* Fix terminal internal components interacting with panning */
  :global(#terminal-output) {
    overscroll-behavior: contain;
  }
</style>

<script>
  const viewport = document.getElementById('viewport');
  const canvas = document.getElementById('canvas');
  const cursorDot = document.getElementById('cursor-dot');
  const cursorOutline = document.getElementById('cursor-outline');
  
  if (viewport && canvas) {
    // Canvas State
    let state = {
      x: window.innerWidth / 2, 
      y: window.innerHeight / 2,
      scale: 1,
      isPanning: false,
      spaceBarDown: false,
      lastMouse: { x: 0, y: 0 }
    };

    // Ensure transform origin is 0 0 so zoom math perfectly aligns
    canvas.style.transformOrigin = '0 0';

    // Cursor Logic
    let cursorX = 0;
    let cursorY = 0;
    let outlineX = 0;
    let outlineY = 0;

    const moveCursor = (e: MouseEvent) => {
      cursorX = e.clientX;
      cursorY = e.clientY;
      
      if (cursorDot) {
        cursorDot.style.transform = `translate(${cursorX - 3}px, ${cursorY - 3}px)`;
      }

      // Check for hover states
      const target = e.target as HTMLElement;
      const isHoverable = target.closest('button, a, input, textarea, [role="button"], .cursor-pointer');
      
      if (isHoverable) {
        document.body.classList.add('cursor-hover');
      } else {
        document.body.classList.remove('cursor-hover');
      }
    };

    const animateOutline = () => {
      // Smooth follow for outline
      const distX = cursorX - outlineX;
      const distY = cursorY - outlineY;
      
      outlineX += distX * 0.15;
      outlineY += distY * 0.15;
      
      if (cursorOutline) {
        cursorOutline.style.transform = `translate(${outlineX - 20}px, ${outlineY - 20}px)`;
      }
      
      requestAnimationFrame(animateOutline);
    };
    animateOutline();

    // Rendering
    let frameRequested = false;
    const requestUpdate = (animate = false) => {
      if (!frameRequested) {
        frameRequested = true;
        requestAnimationFrame(() => {
          if (animate) {
            canvas.style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
          } else {
            canvas.style.transition = 'none';
          }
          canvas.style.transform = `translate(${state.x}px, ${state.y}px) scale(${state.scale})`;
          frameRequested = false;
        });
      }
    };

    // Initial position
    requestUpdate();

    // Event Handlers
    const handleWheel = (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.custom-scrollbar') || target.closest('.custom-scrollbar-pirate') || target.closest('#terminal-output')) {
        if (Math.abs(state.scale - 1) < 0.01 && !e.ctrlKey && !e.metaKey) return;
      }

      e.preventDefault();

      const { deltaX, deltaY, clientX, clientY } = e;
      const isZoom = e.ctrlKey || e.metaKey;

      if (isZoom) {
        // High-precision zoom pivot with standard sensitivity
        const zoomSpeed = 0.01;
        const zoomFactor = Math.exp(-deltaY * zoomSpeed);
        const newScale = Math.max(0.05, Math.min(state.scale * zoomFactor, 10));
        
        const scaleDelta = newScale / state.scale;
        
        state.x = clientX - (clientX - state.x) * scaleDelta;
        state.y = clientY - (clientY - state.y) * scaleDelta;
        state.scale = newScale;
      } else {
        // Pan
        state.x -= deltaX;
        state.y -= deltaY;
      }
      
      requestUpdate();
    };

    const handleMouseDown = (e: MouseEvent) => {
      // Figma UX: Spacebar, background click, or Middle Mouse Button (button === 1) to pan.
      if (e.button === 1 || state.spaceBarDown || e.target === viewport || e.target === canvas) {
        e.preventDefault();
        state.isPanning = true;
        viewport.classList.add('is-panning');
        document.body.classList.add('cursor-panning');
        document.body.setAttribute('data-is-panning', 'true');
        
        state.lastMouse.x = e.clientX;
        state.lastMouse.y = e.clientY;
      }
    };

    const handleMouseMove = (e) => {
      moveCursor(e);
      if (state.isPanning) {
        state.x += e.clientX - state.lastMouse.x;
        state.y += e.clientY - state.lastMouse.y;
        requestUpdate();
      }
      state.lastMouse.x = e.clientX;
      state.lastMouse.y = e.clientY;
    };

    const handleMouseUp = () => {
      state.isPanning = false;
      viewport.classList.remove('is-panning');
      document.body.classList.remove('cursor-panning');
      document.body.removeAttribute('data-is-panning');
    };

    // Touch Support Logic
    let lastTouchDistance = 0;
    let isTouchPanning = false;

    const handleTouchStart = (e: TouchEvent) => {
      if (e.touches.length === 1) {
        isTouchPanning = true;
        state.lastMouse.x = e.touches[0].clientX;
        state.lastMouse.y = e.touches[0].clientY;
      } else if (e.touches.length === 2) {
        lastTouchDistance = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
      }
    };

    const handleTouchMove = (e: TouchEvent) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      
      if (e.touches.length === 1 && isTouchPanning) {
        const dx = e.touches[0].clientX - state.lastMouse.x;
        const dy = e.touches[0].clientY - state.lastMouse.y;
        state.x += dx;
        state.y += dy;
        state.lastMouse.x = e.touches[0].clientX;
        state.lastMouse.y = e.touches[0].clientY;
        requestUpdate();
      } else if (e.touches.length === 2) {
        const distance = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
        
        const centerX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
        const centerY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
        
        const zoomFactor = distance / lastTouchDistance;
        const newScale = Math.max(0.1, Math.min(state.scale * zoomFactor, 5));
        
        const worldX = (centerX - state.x) / state.scale;
        const worldY = (centerY - state.y) / state.scale;
        
        state.scale = newScale;
        state.x = centerX - worldX * state.scale;
        state.y = centerY - worldY * state.scale;
        
        lastTouchDistance = distance;
        requestUpdate();
      }
    };

    const handleTouchEnd = () => {
      isTouchPanning = false;
      lastTouchDistance = 0;
    };

    // Bindings
    window.addEventListener('wheel', handleWheel, { passive: false });
    window.addEventListener('mousedown', handleMouseDown);
    window.addEventListener('mousemove', handleMouseMove, { passive: true });
    window.addEventListener('mouseup', handleMouseUp);
    
    // Touch Bindings
    window.addEventListener('touchstart', handleTouchStart, { passive: false });
    window.addEventListener('touchmove', handleTouchMove, { passive: false });
    window.addEventListener('touchend', handleTouchEnd);
    
    // Resize handler to maintain centering
    window.addEventListener('resize', () => {
      requestUpdate();
    });
    
    // Spacebar listener
    window.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      if (e.code === 'Space' && !state.spaceBarDown) {
        e.preventDefault();
        state.spaceBarDown = true;
        // cursor-panning class handles visual feedback
        document.body.classList.add('cursor-panning');
      }
    });

    window.addEventListener('keyup', (e) => {
      if (e.code === 'Space') {
        state.spaceBarDown = false;
        if (!state.isPanning) document.body.classList.remove('cursor-panning');
      }
    });

    // Native gesture blocking and handling for Mac Safari/Chrome
    let gestureStartScale = 1;
    window.addEventListener('gesturestart', (e: any) => {
      e.preventDefault();
      gestureStartScale = state.scale;
    });
    window.addEventListener('gesturechange', (e: any) => {
      e.preventDefault();
      const newScale = Math.max(0.05, Math.min(gestureStartScale * e.scale, 10));
      const scaleDelta = newScale / state.scale;
      
      const cursorX = e.clientX;
      const cursorY = e.clientY;
      
      state.x = cursorX - (cursorX - state.x) * scaleDelta;
      state.y = cursorY - (cursorY - state.y) * scaleDelta;
      state.scale = newScale;
      requestUpdate();
    });
    window.addEventListener('gestureend', (e: any) => e.preventDefault());
    
    document.getElementById('btn-zoom-out')?.addEventListener('click', () => {
      // Center and show all
      state.x = (window.innerWidth / 2) - (1200 * 0.3); 
      state.y = window.innerHeight / 2;
      state.scale = 0.3;
      requestUpdate(true);
    });

    // Mobile nav buttons logic
    document.getElementById('btn-home')?.addEventListener('click', () => {
      state.x = window.innerWidth / 2;
      state.y = window.innerHeight / 2;
      state.scale = 1;
      requestUpdate(true);
    });
    document.getElementById('btn-notebook')?.addEventListener('click', () => {
      state.x = (window.innerWidth / 2) - (1200 * 1);
      state.y = window.innerHeight / 2;
      state.scale = 1;
      requestUpdate(true);
    });
    document.getElementById('btn-gallery')?.addEventListener('click', () => {
      state.x = (window.innerWidth / 2) - (2400 * 1);
      state.y = window.innerHeight / 2;
      state.scale = 1;
      requestUpdate(true);
    });

    // Mobile Quick Commands Logic
    document.querySelectorAll('.quick-cmd-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cmd = btn.getAttribute('data-cmd');
        if (cmd) {
          window.dispatchEvent(new CustomEvent('terminal:execute', { detail: { command: cmd } }));
          // Jump back to terminal to see output
          state.x = window.innerWidth / 2;
          state.y = window.innerHeight / 2;
          state.scale = 1;
          requestUpdate(true);
        }
      });
    });
  }
</script>

