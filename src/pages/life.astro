---
import Layout from '../layouts/Layout.astro';
import { postcards } from '../lib/life_data';
import { Image } from 'astro:assets';

// Sorting by date or just keeping as is
const sortedPostcards = [...postcards];
---

<Layout title="bigf.me - Life Postcards">
  <div class="min-h-screen bg-[#0a0a0f] text-[#e2e8f0] flex flex-col grid-bg monitor-warp scanlines pb-20">
    <div class="vaporwave-bg"></div>
    <div class="vaporwave-sunset"></div>
    <div class="scanline-moving"></div>

    <!-- Navigation Header -->
    <header class="p-6 md:p-10 flex justify-between items-center relative z-10">
      <a href="/" class="text-[#ff6b9d] font-mono hover:text-[#00d4ff] transition-colors flex items-center gap-2">
        <span class="text-xl">←</span> cd ..
      </a>
      <h1 class="text-2xl md:text-4xl font-bold text-[#e2e8f0] tracking-tighter italic">LIFE_REFLECTIONS</h1>
    </header>

    <!-- Postcard List -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-4 space-y-24 py-10">
      {sortedPostcards.map((post, index) => (
        <div class={`postcard-container group perspective-1000 ${index % 2 === 0 ? 'rotate-[-1deg]' : 'rotate-[1deg]'} hover:rotate-0 transition-all duration-500`}>
          <div class="postcard relative bg-white p-4 pb-16 md:p-6 md:pb-24 shadow-2xl shadow-black/50 overflow-hidden transform-gpu group-hover:scale-[1.02] transition-transform">
            <!-- Stamp/Marking -->
            <div class="absolute top-4 right-4 md:top-8 md:right-8 w-16 h-16 md:w-24 md:h-24 opacity-20 border-4 border-black/30 rounded-full flex items-center justify-center rotate-12 pointer-events-none">
              <span class="text-[10px] md:text-xs font-bold text-center text-black leading-none uppercase tracking-widest">
                BIGF.ME<br/>POSTAGE<br/>{post.date}
              </span>
            </div>

            <!-- Image -->
            <div class="relative w-full aspect-[4/3] bg-[#f0f0f0] overflow-hidden">
              <Image 
                src={post.image} 
                alt={post.title} 
                class="w-full h-full object-cover"
                width={800}
                height={600}
              />
              <div class="absolute inset-0 shadow-[inset_0_0_40px_rgba(0,0,0,0.1)]"></div>
            </div>

            <!-- Content Area (Polaroid-style caption) -->
            <div class="mt-4 md:mt-8 space-y-2">
              <div class="flex justify-between items-end">
                <h2 class="font-['Caveat'] text-2xl md:text-4xl text-black/80 font-bold">{post.title}</h2>
                <span class="font-['Patrick_Hand'] text-sm md:text-base text-black/40 italic">{post.location}</span>
              </div>
              <p class="font-['Patrick_Hand'] text-lg md:text-2xl text-black/70 leading-relaxed max-w-[90%]">
                {post.caption}
              </p>
            </div>

            <!-- Decorative Tape/Corners -->
            <div class="absolute -top-2 left-1/2 -translate-x-1/2 w-24 h-8 bg-[#fdf2f2]/40 backdrop-blur-sm -rotate-2 opacity-50"></div>
          </div>
          
          <!-- Shadow effect behind postcard -->
          <div class="absolute inset-0 bg-black/20 -z-10 blur-xl translate-y-4 translate-x-2 rounded-lg opacity-40 group-hover:opacity-60 transition-opacity"></div>
        </div>
      ))}
    </main>

    <footer class="text-center p-20 text-[#6b7280] font-mono text-xs relative z-10">
      <p>END OF STREAM // ALL MOMENTS CAPTURED</p>
      <a href="/" class="mt-4 inline-block px-4 py-2 border border-[#2a2a3f] hover:border-[#ff6b9d] hover:text-[#ff6b9d] transition-all">RETURN TO TERMINAL</a>
    </footer>
  </div>
</Layout>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  
  .postcard {
    /* Slight paper texture */
    background-image: 
      radial-gradient(#00000005 1px, transparent 1px),
      linear-gradient(rgba(0,0,0,0.02) 1px, transparent 1px);
    background-size: 20px 20px, 100% 40px;
  }

  .postcard::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, transparent 50%, rgba(0,0,0,0.05) 100%);
    pointer-events: none;
  }

  /* Custom fonts for the handwritten look */
  h2, p, span {
    color: #1a1a1a;
  }

  @media (max-width: 768px) {
    .perspective-1000 {
      perspective: none;
    }
  }
</style>
