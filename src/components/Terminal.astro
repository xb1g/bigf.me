---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<!-- CRT Monitor Wrapper for Desktop -->
<div class="absolute w-full h-full inset-0 bg-black md:flex md:items-center md:justify-center z-0 overflow-hidden rounded-[3rem]">
  <!-- The CRT Bezel -->
  <div class="w-full h-full md:rounded-[3rem] md:border-[24px] border border-[#2a2a3f] md:border-[#1a1a24] shadow-[0_20px_60px_rgba(0,0,0,0.9),inset_0_0_30px_rgba(0,0,0,1)] relative mx-auto bg-[#0a0a0f] flex flex-col md:resize md:overflow-hidden" style="min-width: 320px;">
    <!-- Inner Monitor Screen Glass/Shadow -->
    <div class="hidden md:block absolute inset-0 pointer-events-none md:rounded-[1.5rem] shadow-[inset_0_0_100px_rgba(0,0,0,0.95)] z-[70]"></div>
    
    <div id="terminal" class:list={["flex-1 h-full bg-[#0a0a0f] text-[#e2e8f0] flex flex-col grid-bg monitor-warp scanlines relative rounded-[1rem] md:rounded-none overflow-hidden", className]}>
  <!-- Construction Tape -->
  <div class="w-full h-8 construction-tape flex items-center justify-center z-[60] shadow-[0_4px_15px_rgba(0,0,0,0.8)] border-b-2 border-black relative">
    <div class="bg-black px-6 py-0.5 text-[#facc15] font-mono font-bold text-xs md:text-sm tracking-widest flex items-center gap-4 whitespace-nowrap whitespace-pre">
      <span>🚧</span>
      <span>SITE UNDER CONSTRUCTION</span>
      <span>🚧</span>
    </div>
  </div>

  <div class="scanline-moving"></div>
  <div class="tracking-line"></div>
  
  <!-- Terminal Output Area -->
  <div id="terminal-output" class="flex-1 overflow-x-hidden overflow-y-auto p-4 pb-[140px] font-mono text-sm md:text-base w-full mx-auto relative z-10 custom-scrollbar block">
    <!-- Welcome Message -->
    <div class="mb-6">
      <div class="text-[#39ff14] font-bold text-lg mb-2">Welcome to bigf.me</div>
      <div class="text-[#ff6b9d] text-sm mb-1">Type 'help' or click a quick button below</div>
    </div>
  </div>

  <!-- Bottom Control Area -->
  <div class="absolute bottom-0 left-0 right-0 flex flex-col z-50">
    <!-- Quick Buttons Bar -->
    <div class="relative group/bar bg-[#0a0a0f]/40 backdrop-blur-xl border-t border-[#2a2a3f]/40 px-4 py-2 overflow-hidden">
      <div class="relative z-10 flex items-center gap-4 max-w-4xl mx-auto overflow-x-auto scrollbar-hide">
        <span class="text-[#6b7280] text-[10px] uppercase tracking-widest shrink-0 font-bold opacity-40">Quick</span>
        
        <!-- HIGHLIGHTS Button - Custom hover -->
        <button 
          class="highlight-btn px-3 py-1 border border-[#ff6b9d]/30 rounded-full text-xs text-[#ff6b9d]/80 hover:text-white hover:bg-[#ff6b9d] hover:shadow-[0_0_20px_rgba(255,107,157,0.4)] transition-all duration-300 shrink-0" 
          data-cmd="highlights"
        >
          highlights
        </button>
        
        <button class="quick-btn px-3 py-1 border border-[#e2e8f0]/10 rounded-full text-xs text-[#e2e8f0]/50 hover:text-[#00d4ff] hover:border-[#00d4ff]/30 hover:bg-[#00d4ff]/5 hover:shadow-[0_0_15px_rgba(0,212,255,0.2)] transition-all duration-300 shrink-0" data-cmd="whoami">whoami</button>
        <button class="quick-btn px-3 py-1 border border-[#e2e8f0]/10 rounded-full text-xs text-[#e2e8f0]/50 hover:text-[#00d4ff] hover:border-[#00d4ff]/30 hover:bg-[#00d4ff]/5 hover:shadow-[0_0_15px_rgba(0,212,255,0.2)] transition-all duration-300 shrink-0" data-cmd="ls">ls</button>
        <button class="quick-btn px-3 py-1 border border-[#e2e8f0]/10 rounded-full text-xs text-[#e2e8f0]/50 hover:text-[#00d4ff] hover:border-[#00d4ff]/30 hover:bg-[#00d4ff]/5 hover:shadow-[0_0_15px_rgba(0,212,255,0.2)] transition-all duration-300 shrink-0" data-cmd="cat about">about</button>
        <button class="quick-btn px-3 py-1 border border-[#39ff14]/10 rounded-full text-xs text-[#39ff14]/60 hover:text-[#39ff14] hover:border-[#39ff14]/30 hover:bg-[#39ff14]/5 hover:shadow-[0_0_15px_rgba(57,255,20,0.2)] transition-all duration-300 shrink-0" data-cmd="cat life">life</button>
        <button class="quick-btn px-3 py-1 border border-[#e2e8f0]/10 rounded-full text-xs text-[#e2e8f0]/50 hover:text-[#00d4ff] hover:border-[#00d4ff]/30 hover:bg-[#00d4ff]/5 hover:shadow-[0_0_15px_rgba(0,212,255,0.2)] transition-all duration-300 shrink-0" data-cmd="cat books">books</button>
        <button class="quick-btn px-3 py-1 border border-[#e2e8f0]/10 rounded-full text-xs text-[#e2e8f0]/50 hover:text-[#00d4ff] hover:border-[#00d4ff]/30 hover:bg-[#00d4ff]/5 hover:shadow-[0_0_15px_rgba(0,212,255,0.2)] transition-all duration-300 shrink-0" data-cmd="cat philosophy">philosophy</button>
        <button class="quick-btn px-3 py-1 border border-[#e2e8f0]/10 rounded-full text-xs text-[#e2e8f0]/50 hover:text-[#00d4ff] hover:border-[#00d4ff]/30 hover:bg-[#00d4ff]/5 hover:shadow-[0_0_15px_rgba(0,212,255,0.2)] transition-all duration-300 shrink-0" data-cmd="cat now">now</button>
        <button class="quick-btn px-3 py-1 border border-[#e2e8f0]/10 rounded-full text-xs text-[#e2e8f0]/50 hover:text-[#00d4ff] hover:border-[#00d4ff]/30 hover:bg-[#00d4ff]/5 hover:shadow-[0_0_15px_rgba(0,212,255,0.2)] transition-all duration-300 shrink-0" data-cmd="pretext">pretext</button>
        <button class="quick-btn px-3 py-1 border border-[#a78bfa]/20 rounded-full text-xs text-[#a78bfa]/70 hover:text-[#a78bfa] hover:border-[#a78bfa]/40 hover:bg-[#a78bfa]/10 hover:shadow-[0_0_15px_rgba(167,139,250,0.2)] transition-all duration-300 shrink-0 flex items-center gap-1" data-cmd="ai "><span class="text-[10px]">🤖</span> ask ai</button>
        
        <div class="ml-auto flex items-center gap-2">
          <button class="quick-btn px-3 py-1 border border-transparent rounded-full text-xs text-[#6b7280]/40 hover:text-[#ff6b9d] transition-all duration-300 shrink-0" data-cmd="clear">clear</button>
        </div>
      </div>
    </div>

    <!-- Active Prompt - Attached to very bottom -->
    <div class="bg-[#0a0a0f]/95 backdrop-blur-sm border-t border-[#2a2a3f] p-3">
      <div class="flex items-center gap-2 max-w-4xl mx-auto">
        <span class="text-[#ff6b9d] shrink-0 font-semibold">bigseed@bigf.me</span>
        <span class="text-[#6b7280]">:</span>
        <span id="current-path" class="text-[#00d4ff]">~</span>
        <span class="text-[#e2e8f0]">$</span>
        <input
          id="terminal-input"
          type="text"
          class="flex-1 bg-transparent text-[#e2e8f0] outline-none font-mono text-sm md:text-base min-w-0 caret-[#00d4ff]"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        />
      </div>
    </div>


  </div>
    </div>
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  @keyframes tape-scroll {
    from { background-position: 0 0; }
    to { background-position: -56.57px 0; }
  }

  .construction-tape {
    background: repeating-linear-gradient(
      -45deg,
      #facc15,
      #facc15 20px,
      #000000 20px,
      #000000 40px
    );
    background-size: 56.57px 56.57px;
    animation: tape-scroll 2s linear infinite;
  }

  /* ── Reasoning stream animations ── */

  @keyframes think-glow {
    0%, 100% { text-shadow: 0 0 4px #a78bfa44, 0 0 8px #a78bfa22; opacity: 0.55; }
    50%       { text-shadow: 0 0 8px #a78bfa99, 0 0 20px #a78bfa44; opacity: 0.85; }
  }

  @keyframes think-border-pulse {
    0%, 100% { border-color: #a78bfa22; box-shadow: inset 0 0 12px #a78bfa08; }
    50%       { border-color: #a78bfa55; box-shadow: inset 0 0 20px #a78bfa18, 0 0 8px #a78bfa22; }
  }

  @keyframes char-in {
    from { opacity: 0; transform: translateX(-3px); filter: blur(1.5px); }
    to   { opacity: 1; transform: translateX(0);    filter: blur(0); }
  }

  @keyframes think-scanline {
    from { top: 0%; }
    to   { top: 100%; }
  }

  @keyframes synthesis-flash {
    0%   { opacity: 1; background: #a78bfa22; }
    40%  { opacity: 1; background: #a78bfa55; box-shadow: 0 0 30px #a78bfa66; }
    100% { opacity: 0; height: 0; padding: 0; margin: 0; overflow: hidden; }
  }

  @keyframes think-header-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0.3; }
  }

  @keyframes answer-slide-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .think-block {
    border: 1px solid #a78bfa22;
    background: linear-gradient(135deg, #0a0a18 0%, #0d0a1a 100%);
    border-radius: 3px;
    position: relative;
    overflow: hidden;
    animation: think-border-pulse 2.4s ease-in-out infinite;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .think-block.collapsed {
    animation: synthesis-flash 0.6s ease-out forwards;
  }

  .think-scanline-bar {
    position: absolute;
    left: 0; right: 0;
    height: 18px;
    background: linear-gradient(180deg, transparent, #a78bfa0a 50%, transparent);
    pointer-events: none;
    animation: think-scanline 2.8s linear infinite;
  }

  .think-header {
    animation: think-glow 1.8s ease-in-out infinite;
  }

  .think-dot {
    animation: think-header-blink 0.9s step-start infinite;
  }

  .think-char {
    display: inline;
    animation: char-in 0.06s ease-out both;
  }

  /* Variable font weight cycling — mapped by char position mod classes */
  .w-thin   { font-weight: 100; opacity: 0.4; letter-spacing: 0.02em; }
  .w-light  { font-weight: 300; opacity: 0.6; letter-spacing: 0.01em; }
  .w-normal { font-weight: 400; opacity: 0.75; }
  .w-medium { font-weight: 500; opacity: 0.85; }
  .w-bold   { font-weight: 700; opacity: 0.95; letter-spacing: -0.01em; }
  .w-black  { font-weight: 900; opacity: 1.0;  letter-spacing: -0.02em; }

  .ai-answer-block {
    animation: answer-slide-in 0.35s ease-out both;
  }
</style>


<script>
  import { executeCommand, projects, categories } from '../lib/commands.ts';
  import { createProjectCard, createCarousel } from './ProjectCard.ts';
  import { createThemePicker } from './ThemePicker.ts';
  import type { Project } from '../lib/commands.ts';

  // Listen for global execute commands (e.g. from mobile dock)
  window.addEventListener('terminal:execute', (e: any) => {
    execute(e.detail.command);
  });

  // Backend API endpoint (no API key exposed client-side)

  const terminal = document.getElementById('terminal-output');
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const currentPathEl = document.getElementById('current-path');

  let currentPath = '~';
  let commandHistory: string[] = [];
  let historyIndex = -1;

  function scrollToBottom() {
    if (terminal) {
      requestAnimationFrame(() => {
        terminal.scrollTop = terminal.scrollHeight;
        setTimeout(() => {
          terminal.scrollTop = terminal.scrollHeight;
        }, 50);
      });
    }
  }

  function addCommandToOutput(command: string) {
    const cmdLine = document.createElement('div');
    cmdLine.className = 'mb-2';
    cmdLine.innerHTML = `
      <span class="text-[#ff6b9d] font-semibold">bigseed@bigf.me</span>
      <span class="text-[#6b7280]">:</span>
      <span class="text-[#00d4ff]">${currentPath}</span>
      <span class="text-[#e2e8f0]">$</span>
      <span class="text-[#e2e8f0] ml-2">${command}</span>
    `;
    terminal?.appendChild(cmdLine);
    scrollToBottom();
  }

  let prepareWithSegments: any, layoutWithLines: any;
  let pretextLoaded = false;
  let textBlocksCache: { id: number, text: string, isError: boolean, prepared: any, el: HTMLElement }[] = [];
  let nextBlockId = 0;

  // Initialize Pretext globally
  import('https://esm.sh/@chenglou/pretext@1.0.3').then((mod) => {
    prepareWithSegments = mod.prepareWithSegments;
    layoutWithLines = mod.layoutWithLines;
    pretextLoaded = true;
    
    // Setup resize observer on terminal to reflow all text using pretext
    const resizeObserver = new ResizeObserver(() => {
       if (!pretextLoaded || !terminal) return;
       requestAnimationFrame(() => {
         const width = terminal.clientWidth - 32; // taking padding into account
         // Reflow all saved text blocks
         textBlocksCache.forEach(block => {
            if (!block.el.isConnected) return;
            const { height, lines } = layoutWithLines(block.prepared, width, 24);
            
            block.el.style.height = height + 'px';
            block.el.innerHTML = '';
            
            lines.forEach((line: any) => {
               const lineEl = document.createElement('div');
               lineEl.className = 'whitespace-pre absolute left-0';
               lineEl.style.top = (line.start.segmentIndex * 24) + 'px'; // Pretext doesn't expose line y natively but we can do index * 24
            });
            // Better rendering approach since layoutWithLines gives us the ordered lines:
            let html = '';
            for (let i = 0; i < lines.length; i++) {
               let formattedLine = lines[i].text
                  .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
                  .replace(/^###\s+(.+)$/g, '<span class="text-[#b829dd] font-bold text-md block mt-2 mb-1">### $1</span>')
                  .replace(/^##\s+(.+)$/g, '<span class="text-[#00d4ff] font-bold text-lg block mt-3 mb-1">## $1</span>')
                  .replace(/^#\s+(.+)$/g, '<span class="text-[#39ff14] font-bold text-xl block mt-4 mb-2"># $1</span>')
                  .replace(/^&gt;\s+(.+)$/g, '<span class="text-[#a78bfa] italic border-l-2 border-[#a78bfa] pl-2 block my-2">&gt; $1</span>')
                  .replace(/\*\*(.*?)\*\*/g, '<span class="font-bold text-[#facc15]">$1</span>')
                  .replace(/(^|[^\*])\*([^\*]+)\*(?!\*)/g, '$1<span class="italic text-[#a78bfa]">$2</span>')
                  .replace(/^-\s+(.+)$/g, '<span class="text-[#ff6b9d]">-</span> <span class="text-[#e2e8f0]">$1</span>')
                  .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a target="_blank" href="$2" class="text-[#00d4ff] underline hover:text-[#ff6b9d] transition-colors">$1</a>')
                  .replace(/^drwxr-xr-x\s+(.+)$/g, '<span class="text-[#6b7280]">drwxr-xr-x</span>  <span class="text-[#00d4ff] font-bold">$1</span>')
                  .replace(/^-rw-r--r--\s+(.+)$/g, '<span class="text-[#6b7280]">-rw-r--r--</span>  <span class="text-[#e2e8f0]">$1</span>');
               
               html += `<div class="whitespace-pre overflow-hidden h-[24px] absolute left-0 text-ellipsis ${block.isError ? 'text-[#ff6b9d]' : 'text-[#e2e8f0]'}" style="top: ${i * 24}px">${formattedLine}</div>`;
            }
            block.el.innerHTML = html;
         });
       });
    });
    if (terminal) resizeObserver.observe(terminal);
  });

  function addOutputToTerminal(output: string, isError = false, element?: HTMLElement) {
    if (output === '__CLEAR__') {
      if (terminal) {
        terminal.innerHTML = '';
        textBlocksCache = [];
        const welcome = document.createElement('div');
        welcome.className = 'mb-6';
        welcome.innerHTML = `
          <div class="text-[#39ff14] font-bold text-lg mb-2">Welcome to bigf.me</div>
          <div class="text-[#ff6b9d] text-sm mb-1">Type 'help' or click a quick button below</div>
        `;
        terminal.appendChild(welcome);
      }
      return;
    }

    if (output.startsWith('__PRETEXT__')) {
        output = output.substring('__PRETEXT__'.length); // For the pretext command, just render it as normal text now since the WHOLE terminal is pretext powered
    }

    if (output === '__THEME_PICKER__') {
      const picker = createThemePicker();
      terminal?.appendChild(picker);
      scrollToBottom();
      return;
    }

    if (element) {
      terminal?.appendChild(element);
    } else {
      const outputDiv = document.createElement('div');
      outputDiv.className = `mb-4 relative w-full`;
      
      if (pretextLoaded) {
          // Process using pretext for exact line rendering
          const font = '14px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace';
          // Sanitize raw output and prepare
          const prepared = prepareWithSegments(output, font);
          
          textBlocksCache.push({
              id: nextBlockId++,
              text: output,
              isError,
              prepared,
              el: outputDiv
          });
          
          const width = terminal!.clientWidth - 32;
          const { height, lines } = layoutWithLines(prepared, width, 24);
          outputDiv.style.height = height + 'px';
          
          let html = '';
          for (let i = 0; i < lines.length; i++) {
             let formattedLine = lines[i].text
                .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
                .replace(/^###\s+(.+)$/g, '<span class="text-[#b829dd] font-bold text-md block mt-2 mb-1">### $1</span>')
                .replace(/^##\s+(.+)$/g, '<span class="text-[#00d4ff] font-bold text-lg block mt-3 mb-1">## $1</span>')
                .replace(/^#\s+(.+)$/g, '<span class="text-[#39ff14] font-bold text-xl block mt-4 mb-2"># $1</span>')
                .replace(/^&gt;\s+(.+)$/g, '<span class="text-[#a78bfa] italic border-l-2 border-[#a78bfa] pl-2 block my-2">&gt; $1</span>')
                .replace(/\*\*(.*?)\*\*/g, '<span class="font-bold text-[#facc15]">$1</span>')
                .replace(/(^|[^\*])\*([^\*]+)\*(?!\*)/g, '$1<span class="italic text-[#a78bfa]">$2</span>')
                .replace(/^-\s+(.+)$/g, '<span class="text-[#ff6b9d]">-</span> <span class="text-[#e2e8f0]">$1</span>')
                .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a target="_blank" href="$2" class="text-[#00d4ff] underline hover:text-[#ff6b9d] transition-colors">$1</a>')
                .replace(/^drwxr-xr-x\s+(.+)$/g, '<span class="text-[#6b7280]">drwxr-xr-x</span>  <span class="text-[#00d4ff] font-bold">$1</span>')
                .replace(/^-rw-r--r--\s+(.+)$/g, '<span class="text-[#6b7280]">-rw-r--r--</span>  <span class="text-[#e2e8f0]">$1</span>');
             
             html += `<div class="whitespace-pre overflow-hidden h-[24px] absolute left-0 text-ellipsis ${isError ? 'text-[#ff6b9d]' : 'text-[#e2e8f0]'}" style="top: ${i * 24}px">${formattedLine}</div>`;
          }
          outputDiv.innerHTML = html;
      } else {
          // Fallback if pretext script fails to load
          outputDiv.className += ` whitespace-pre-wrap ${isError ? 'text-[#ff6b9d]' : 'text-[#e2e8f0]'}`;
          if (isError) {
            outputDiv.textContent = output;
          } else {
            let formattedOutput = output
              .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
            outputDiv.innerHTML = formattedOutput;
          }
      }
      
      terminal?.appendChild(outputDiv);
    }
    scrollToBottom();
  }

  // ── Rate limiting ──────────────────────────────────────────────
  const AI_REQUEST_TIMESTAMPS: number[] = [];
  const AI_RATE_LIMIT = 5;       // max requests
  const AI_RATE_WINDOW = 60_000; // per 60 seconds

  function checkAIRateLimit(): { allowed: boolean; waitMs: number } {
    const now = Date.now();
    // Evict timestamps outside window
    while (AI_REQUEST_TIMESTAMPS.length && now - AI_REQUEST_TIMESTAMPS[0] > AI_RATE_WINDOW) {
      AI_REQUEST_TIMESTAMPS.shift();
    }
    if (AI_REQUEST_TIMESTAMPS.length >= AI_RATE_LIMIT) {
      const waitMs = AI_RATE_WINDOW - (now - AI_REQUEST_TIMESTAMPS[0]);
      return { allowed: false, waitMs };
    }
    AI_REQUEST_TIMESTAMPS.push(now);
    return { allowed: true, waitMs: 0 };
  }

  // ── Variable-weight char classes (sinusoidal cycle) ────────────
  const WEIGHT_CYCLE = ['w-thin','w-light','w-normal','w-medium','w-bold','w-black','w-bold','w-medium','w-normal','w-light'];

  function makeThinkChar(ch: string, globalIdx: number): string {
    if (ch === '\n') return '<br>';
    if (ch === ' ')  return '<span class="think-char" style="animation-delay:' + (Math.min(globalIdx * 0.012, 1.5)) + 's"> </span>';
    const wClass   = WEIGHT_CYCLE[globalIdx % WEIGHT_CYCLE.length];
    const delay    = Math.min(globalIdx * 0.012, 1.5);
    // Purple hue varies slightly by weight class for depth
    const hue      = 265 + (globalIdx % 7) * 3;
    const lit      = 65 + (globalIdx % 5) * 4;
    const escaped  = ch.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return `<span class="think-char ${wClass}" style="animation-delay:${delay}s;color:hsl(${hue},70%,${lit}%)">${escaped}</span>`;
  }

  // ── Main AI handler ─────────────────────────────────────────────
  async function handleAICommand(query: string) {
    // Rate limit check
    const rl = checkAIRateLimit();
    if (!rl.allowed) {
      const secs = Math.ceil(rl.waitMs / 1000);
      const errDiv = document.createElement('div');
      errDiv.className = 'mb-4 font-mono text-xs';
      errDiv.innerHTML = `<span style="color:#ff6b9d">◈ rate limit</span>  <span style="color:#6b7280">try again in ${secs}s  (max ${AI_RATE_LIMIT} req/min)</span>`;
      terminal?.appendChild(errDiv);
      scrollToBottom();
      input.value = '';
      return;
    }

    // ── Outer wrapper ──────────────────────────────────────────────
    const aiContainer = document.createElement('div');
    aiContainer.className = 'mb-6 relative w-full';

    // ── Simple loading indicator ─────────────────────────────────
    const loadingEl = document.createElement('div');
    loadingEl.className = 'font-mono text-xs text-[#a78bfa] mb-2';
    loadingEl.textContent = 'thinking...';
    aiContainer.appendChild(loadingEl);

    // ── Answer block ──────────────────────────────────────────────
    const answerBlock = document.createElement('div');
    answerBlock.className = 'ai-answer-block font-mono text-sm whitespace-pre-wrap leading-relaxed';
    answerBlock.style.color = '#e2e8f0';
    answerBlock.innerHTML = '<span style="color:#a78bfa;animation:think-header-blink 0.9s step-start infinite">_</span>';
    aiContainer.appendChild(answerBlock);

    terminal?.appendChild(aiContainer);
    scrollToBottom();

    // ── Stream state ──────────────────────────────────────────────
    let answerText = '';
    let answerCharCount = 0;

    // ── Fetch ─────────────────────────────────────────────────────
    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ query })
      });

      if (!response.ok) {
        const errText = await response.text();
        thinkBlock.remove();
        answerBlock.style.color = '#ff6b9d';
        answerBlock.textContent = `Error ${response.status}: ${errText.slice(0, 200)}`;
        scrollToBottom();
        input.value = '';
        return;
      }

      const reader   = response.body?.getReader();
      const decoder  = new TextDecoder();
      if (!reader) { answerBlock.textContent = 'Error: no body'; input.value = ''; return; }

      let sseBuffer = '';

      // Remove loading indicator once stream starts
      loadingEl.remove();

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        sseBuffer += decoder.decode(value, { stream: true });
        const lines = sseBuffer.split('\n');
        sseBuffer = lines.pop() ?? '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const payload = line.slice(6).trim();
          if (payload === '[DONE]') continue;

          try {
            const chunk = JSON.parse(payload);
            const content: string | undefined = chunk.choices?.[0]?.delta?.content;
            if (!content) continue;

            answerText += content;
            answerBlock.textContent = answerText + '_';
            answerCharCount = answerText.length;
          } catch (_) { /* skip malformed */ }
        }

        scrollToBottom();
      }

      // Final answer without cursor
      answerBlock.textContent = answerText.trim();

    } catch (err: any) {
      loadingEl.remove();
      answerBlock.style.color = '#ff6b9d';
      answerBlock.textContent = `connection error: ${err.message}`;
    }

    scrollToBottom();
    input.value = '';
  }

  function renderProjectCards(projectList: string[], categoryName?: string) {

    if (projectList.length === 0) return null;
    
    const projectData = projectList
      .map(id => ({ ...projects[id], id }))
      .filter(p => p.name);
    
    const cards = projectData.map(p => 
      createProjectCard({
        project: p,
        onClick: (projectId) => {
          const cmd = categoryName ? `cd ${categoryName}/${projectId}` : `cd ${projectId}`;
          execute(cmd);
          execute('ls');
        }
      })
    );
    
    return createCarousel({
      title: categoryName ? `${categoryName} projects` : 'Projects',
      items: cards
    });
  }

  function execute(cmd: string) {
    if (!cmd.trim()) return;

    commandHistory.push(cmd);
    historyIndex = commandHistory.length;

    addCommandToOutput(cmd);

    const parts = cmd.trim().split(' ');
    const command = parts[0].toLowerCase();
    const args = parts.slice(1);

    // Handle highlights command - show curated best projects (optimized for Eigen)
    if (command === 'highlights') {
      const highlightProjects = ['passionseed', 'fync', 'longkeeb', 'hive', 'careerac'];
      const carousel = renderProjectCards(highlightProjects);
      if (carousel) {
        addOutputToTerminal('', false, carousel);
      }
      addOutputToTerminal(`✨ HIGHLIGHTS

These are the projects I'm most proud of:

• PassionSeed - AI career discovery for students (300 hackathon users)
• Fync - Friendship graph API (early exploration in relationship modeling)
• LongKeeb/Portex - Hardware keyboards I designed and sold
• Hive - AI democracy tool (Gemini hackathon semi-finalist)
• CareerAc - Career planning AI (Berkeley Challenge Lab)

Click any card to explore, or use 'cd [project]' to navigate deeper.

Type 'cat life' for music, places, and art.`);
      input.value = '';
      scrollToBottom();
      return;
    }

    // Handle ls with visual cards
    if (command === 'ls') {
      const target = args[0] || currentPath;
      
      // Home - show all categories with cards
      if (target === '~' || target === '/' || target === 'home') {
        // Show categories as cards
        const categoryCards = Object.entries(categories).map(([cat, projs]) => {
          const card = document.createElement('div');
          card.className = 'flex-shrink-0 w-48 bg-[#15151f] border border-[#2a2a3f] rounded-lg p-4 cursor-pointer hover:border-[#ff6b9d] transition-all group';
          card.innerHTML = `
            <div class="text-2xl mb-2">${getCategoryIcon(cat)}</div>
            <h3 class="text-sm font-semibold text-[#e2e8f0] group-hover:text-[#ff6b9d] transition-colors capitalize">${cat}</h3>
            <p class="text-xs text-[#6b7280] mt-1">${projs.length} projects</p>
          `;
          card.addEventListener('click', () => {
            execute(`cd ${cat}`);
            execute('ls');
          });
          return card;
        });
        
        const carousel = createCarousel({ title: 'Categories', items: categoryCards });
        addOutputToTerminal('', false, carousel);
        
        // Also show text output
        addOutputToTerminal(`drwxr-xr-x  categories/
drwxr-xr-x  pages/

Use 'cd [category]' to explore or click a card above.`, false);
      } 
      // Category - show projects as cards
      else {
        const category = target.split('/')[0];
        const projectList = categories[category];
        if (projectList) {
          const carousel = renderProjectCards(projectList, category);
          if (carousel) {
            addOutputToTerminal('', false, carousel);
          }
          // Also show text list
          const items = projectList.map(p => `drwxr-xr-x  ${p}/`).join('\n');
          addOutputToTerminal(`${category}/:\n${items}\n\nClick a card above or use 'cd [project]' to navigate.`);
        } else {
          addOutputToTerminal(`ls: ${target}: No such directory`, true);
        }
      }
      
      // Update path if needed
      const result = executeCommand(cmd, currentPath);
      if (result.newPath !== undefined) {
        currentPath = result.newPath;
        if (currentPathEl) currentPathEl.textContent = currentPath;
      }
      input.value = '';
      return;
    }

    // Default command execution
    const result = executeCommand(cmd, currentPath);

    // Handle AI command
    if (result.output.startsWith('__AI__')) {
      const query = result.output.slice('__AI__'.length);
      handleAICommand(query);
      return;
    }

    if (command === 'gallery') {
      addOutputToTerminal(result.output, result.error);
      setTimeout(() => {
        window.location.href = '/life';
      }, 1000);
      return;
    }

    addOutputToTerminal(result.output, result.error);

    if (result.newPath !== undefined) {
      currentPath = result.newPath;
      if (currentPathEl) currentPathEl.textContent = currentPath;
    }

    input.value = '';
  }

  function getCategoryIcon(category: string): string {
    const icons: Record<string, string> = {
      hardware: '🔧',
      education: '📚',
      ai: '🤖',
      sustainability: '🌱',
      community: '👥',
      experiments: '🧪'
    };
    return icons[category] || '📁';
  }

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      execute(input.value);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (historyIndex > 0) {
        historyIndex--;
        input.value = commandHistory[historyIndex] || '';
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIndex < commandHistory.length - 1) {
        historyIndex++;
        input.value = commandHistory[historyIndex] || '';
      } else {
        historyIndex = commandHistory.length;
        input.value = '';
      }
    }
  });



  const quickBtns = document.querySelectorAll('.quick-btn');
  quickBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-cmd') || '';
      // If cmd ends with a trailing space (like "ai "), pre-fill input instead of executing
      if (cmd.endsWith(' ')) {
        input.value = cmd;
        input.focus();
        // Move cursor to end
        input.setSelectionRange(cmd.length, cmd.length);
      } else {
        execute(cmd);
      }
    });
  });

  // Also attach click handler to highlight-btn (HIGHLIGHTS button)
  const highlightBtns = document.querySelectorAll('.highlight-btn');
  highlightBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-cmd') || '';
      execute(cmd);
    });
  });

  // Always focus input on load
  input?.focus();
  
  // Auto-copy selection on mouseup
  document.addEventListener('mouseup', async () => {
    const selection = window.getSelection()?.toString();
    if (selection) {
      try {
        await navigator.clipboard.writeText(selection);
      } catch (err) {
        console.error('Failed to copy text', err);
      }
    }
  });

  // Focus input on click, but only if they aren't selecting text
  document.addEventListener('click', () => {
    const selection = window.getSelection()?.toString();
    if (!selection) {
      input?.focus();
    }
  });

  // Random glitch effect generator
  function triggerRandomGlitch() {
    const terminalEl = document.getElementById('terminal');
    const terminalOutputEl = document.getElementById('terminal-output');
    
    // Screen jitter effect
    if (Math.random() > 0.4) {
      terminalEl?.classList.add('glitch-anim');
    }
    
    // RGB split text glitch effect
    if (Math.random() > 0.3) {
      terminalOutputEl?.classList.add('glitch-rgb');
    }
    
    // Remove classes after animation completes (allow margin for CSS 0.25s length)
    setTimeout(() => {
      terminalEl?.classList.remove('glitch-anim');
      terminalOutputEl?.classList.remove('glitch-rgb');
    }, 300);
    
    // Schedule next glitch between 2 and 15 seconds
    const nextGlitchTime = Math.random() * 13000 + 2000;
    setTimeout(triggerRandomGlitch, nextGlitchTime);
  }
  
  // Start glitch loop soon after load
  setTimeout(triggerRandomGlitch, Math.random() * 4000 + 1000);

  setTimeout(scrollToBottom, 100);
</script>
