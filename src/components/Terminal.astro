---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div id="terminal" class:list={["min-h-screen bg-[#0a0a0f] text-[#e2e8f0] flex flex-col grid-bg", className]}>
  <!-- Terminal Output Area -->
  <div id="terminal-output" class="flex-1 overflow-y-auto p-4 pb-36 md:pb-28 font-mono text-sm md:text-base">
    <!-- Welcome Message -->
    <div class="mb-6">
      <div class="text-[#39ff14] font-bold text-lg mb-2">Welcome to bigf.me</div>
      <div class="text-[#ff6b9d] text-sm mb-1">Type 'help' or click a quick button below</div>
      <div class="text-[#6b7280] text-xs">Terminal v1.0 • Synthwave Edition</div>
    </div>
  </div>

  <!-- Active Prompt -->
  <div class="fixed bottom-20 md:bottom-14 left-0 right-0 bg-[#0a0a0f]/95 backdrop-blur-sm border-t border-[#2a2a3f] p-3 md:p-3 z-10">
    <div class="flex items-center gap-2 max-w-4xl mx-auto">
      <span class="text-[#ff6b9d] shrink-0 font-semibold">bigseed@bigf.me</span>
      <span class="text-[#6b7280]">:</span>
      <span id="current-path" class="text-[#00d4ff]">~</span>
      <span class="text-[#e2e8f0]">$</span>
      <input
        id="terminal-input"
        type="text"
        class="flex-1 bg-transparent text-[#e2e8f0] outline-none font-mono text-sm md:text-base min-w-0 caret-[#00d4ff]"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      />
    </div>
  </div>

  <!-- Quick Buttons Bar (above input) -->
  <div class="fixed bottom-[7.5rem] md:bottom-24 left-0 right-0 bg-[#15151f]/95 backdrop-blur-sm border-t border-[#2a2a3f] px-4 py-2 z-10">
    <div class="flex items-center gap-2 max-w-4xl mx-auto overflow-x-auto scrollbar-hide">
      <span class="text-[#6b7280] text-xs shrink-0 mr-1">Quick:</span>
      <button class="quick-btn px-2 py-1 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] hover:text-[#00d4ff] transition-all duration-200 shrink-0" data-cmd="whoami">whoami</button>
      <button class="quick-btn px-2 py-1 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] hover:text-[#00d4ff] transition-all duration-200 shrink-0" data-cmd="ls">ls</button>
      <button class="quick-btn px-2 py-1 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] hover:text-[#00d4ff] transition-all duration-200 shrink-0" data-cmd="cat about">about</button>
      <button class="quick-btn px-2 py-1 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] hover:text-[#00d4ff] transition-all duration-200 shrink-0" data-cmd="cat books">books</button>
      <button class="quick-btn px-2 py-1 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] hover:text-[#00d4ff] transition-all duration-200 shrink-0" data-cmd="cat philosophy">philosophy</button>
      <button class="quick-btn px-2 py-1 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] hover:text-[#00d4ff] transition-all duration-200 shrink-0" data-cmd="cat now">now</button>
      <button class="quick-btn px-2 py-1 bg-[#15151f] border border-[#ff6b9d] rounded text-xs text-[#ff6b9d] hover:bg-[#ff6b9d] hover:text-[#0a0a0f] transition-all duration-200 shrink-0 ml-auto" data-cmd="clear">clear</button>
    </div>
  </div>

  <!-- Mobile Action Bar -->
  <div id="mobile-action-bar" class="fixed bottom-0 left-0 right-0 bg-[#15151f]/95 backdrop-blur-sm border-t border-[#2a2a3f] p-2 md:hidden z-20">
    <div class="flex items-center gap-2 overflow-x-auto scrollbar-hide">
      <button class="command-chip whitespace-nowrap px-3 py-2 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] transition-colors" data-cmd="help">help</button>
      <button class="command-chip whitespace-nowrap px-3 py-2 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] transition-colors" data-cmd="whoami">whoami</button>
      <button class="command-chip whitespace-nowrap px-3 py-2 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] transition-colors" data-cmd="ls">ls</button>
      <button class="command-chip whitespace-nowrap px-3 py-2 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] transition-colors" data-cmd="cat about">about</button>
      <button class="command-chip whitespace-nowrap px-3 py-2 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] transition-colors" data-cmd="cat books">books</button>
      <button class="command-chip whitespace-nowrap px-3 py-2 bg-[#15151f] border border-[#2a2a3f] rounded text-xs text-[#e2e8f0] hover:border-[#00d4ff] transition-colors" data-cmd="clear">clear</button>
      <button id="keyboard-toggle" class="whitespace-nowrap px-3 py-2 bg-[#15151f] border border-[#00d4ff] rounded text-xs text-[#00d4ff] hover:bg-[#00d4ff] hover:text-[#0a0a0f] transition-colors ml-auto">⌨</button>
    </div>
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  import { executeCommand } from '../lib/commands.ts';

  const terminal = document.getElementById('terminal-output');
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const currentPathEl = document.getElementById('current-path');
  const commandChips = document.querySelectorAll('.command-chip');
  const keyboardToggle = document.getElementById('keyboard-toggle');

  let currentPath = '~';
  let commandHistory: string[] = [];
  let historyIndex = -1;

  function scrollToBottom() {
    if (terminal) {
      setTimeout(() => {
        terminal.scrollTop = terminal.scrollHeight;
      }, 10);
    }
  }

  function addCommandToOutput(command: string) {
    const cmdLine = document.createElement('div');
    cmdLine.className = 'mb-2';
    cmdLine.innerHTML = `
      <span class="text-[#ff6b9d] font-semibold">bigseed@bigf.me</span>
      <span class="text-[#6b7280]">:</span>
      <span class="text-[#00d4ff]">${currentPath}</span>
      <span class="text-[#e2e8f0]">$</span>
      <span class="text-[#e2e8f0] ml-2">${command}</span>
    `;
    terminal?.appendChild(cmdLine);
    scrollToBottom();
  }

  function addOutputToTerminal(output: string, isError = false) {
    if (output === '__CLEAR__') {
      if (terminal) {
        terminal.innerHTML = '';
        // Restore welcome message
        const welcome = document.createElement('div');
        welcome.className = 'mb-6';
        welcome.innerHTML = `
          <div class="text-[#39ff14] font-bold text-lg mb-2">Welcome to bigf.me</div>
          <div class="text-[#ff6b9d] text-sm mb-1">Type 'help' or click a quick button below</div>
          <div class="text-[#6b7280] text-xs">Terminal v1.0 • Synthwave Edition</div>
        `;
        terminal.appendChild(welcome);
      }
      return;
    }

    const outputDiv = document.createElement('div');
    outputDiv.className = `mb-4 whitespace-pre-wrap ${isError ? 'text-[#ff6b9d]' : 'text-[#e2e8f0]'}`;
    outputDiv.textContent = output;
    terminal?.appendChild(outputDiv);
    scrollToBottom();
  }

  function execute(cmd: string) {
    if (!cmd.trim()) return;

    commandHistory.push(cmd);
    historyIndex = commandHistory.length;

    addCommandToOutput(cmd);

    const result = executeCommand(cmd, currentPath);
    addOutputToTerminal(result.output, result.error);

    input.value = '';
  }

  // Input event listeners
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      execute(input.value);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (historyIndex > 0) {
        historyIndex--;
        input.value = commandHistory[historyIndex] || '';
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIndex < commandHistory.length - 1) {
        historyIndex++;
        input.value = commandHistory[historyIndex] || '';
      } else {
        historyIndex = commandHistory.length;
        input.value = '';
      }
    }
  });

  // Mobile command chips
  commandChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const cmd = chip.getAttribute('data-cmd') || '';
      execute(cmd);
    });
  });

  // Quick buttons
  const quickBtns = document.querySelectorAll('.quick-btn');
  quickBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-cmd') || '';
      execute(cmd);
    });
  });

  // Keyboard toggle
  keyboardToggle?.addEventListener('click', () => {
    input?.focus();
  });

  // Focus input on desktop
  if (window.innerWidth >= 768) {
    input?.focus();
  }

  // Initial scroll to bottom
  setTimeout(scrollToBottom, 100);
</script>
