---
---

<div class="w-full h-full flex flex-col items-center justify-center bg-[#1a120e] text-[#e8dcb8] overflow-hidden" style="background-image: radial-gradient(circle at center, #2e2016 0%, #1a120e 100%);">
  
  <!-- "Ancient Pirate" Gallery Book -->
  <div class="relative w-[90vw] max-w-5xl h-[80vh] rounded-md shadow-[0_30px_60px_rgba(0,0,0,0.8),_0_0_0_2px_rgba(30,20,15,0.8)] flex flex-col md:flex-row transform-gpu perspective-1000">

    <!-- Leather Cover Texture Overlay -->
    <div class="absolute inset-0 z-0 rounded-md overflow-hidden pointer-events-none mix-blend-overlay opacity-60">
      <svg viewBox="0 0 400 400" width="100%" height="100%" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <filter id="leatherNoise">
          <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="5" result="noise" />
          <feColorMatrix type="matrix" values="1 0 0 0 0  0.8 0 0 0 0  0.6 0 0 0 0  0 0 0 1 0" in="noise" result="coloredNoise" />
        </filter>
        <rect width="100%" height="100%" filter="url(#leatherNoise)" />
      </svg>
    </div>
    
    <!-- Dark Leather Base -->
    <div class="absolute inset-0 bg-[#3d2314] rounded-md z-[-1] border-[4px] border-[#251208]"></div>

    <!-- Spine / Crease -->
    <div class="hidden md:block absolute top-0 bottom-0 left-1/2 w-20 -ml-10 bg-gradient-to-r from-[#201005] via-[#3a1d0d] to-[#201005] shadow-[inset_0_0_20px_rgba(0,0,0,0.8)] z-20 pointer-events-none border-x-2 border-[#1a0c04]">
      <!-- Binding stitches -->
      <div class="absolute top-[10%] left-1/2 w-6 -ml-3 h-[2px] bg-[#8a684b] shadow-[0_1px_2px_rgba(0,0,0,0.5)]"></div>
      <div class="absolute top-[12%] left-1/2 w-6 -ml-3 h-[2px] bg-[#8a684b] shadow-[0_1px_2px_rgba(0,0,0,0.5)]"></div>
      <div class="absolute top-[50%] left-1/2 w-6 -ml-3 h-[2px] bg-[#8a684b] shadow-[0_1px_2px_rgba(0,0,0,0.5)]"></div>
      <div class="absolute top-[52%] left-1/2 w-6 -ml-3 h-[2px] bg-[#8a684b] shadow-[0_1px_2px_rgba(0,0,0,0.5)]"></div>
      <div class="absolute top-[90%] left-1/2 w-6 -ml-3 h-[2px] bg-[#8a684b] shadow-[0_1px_2px_rgba(0,0,0,0.5)]"></div>
      <div class="absolute top-[92%] left-1/2 w-6 -ml-3 h-[2px] bg-[#8a684b] shadow-[0_1px_2px_rgba(0,0,0,0.5)]"></div>
    </div>
    
    <!-- Bookmark String -->
    <div class="hidden md:block absolute top-[0%] left-1/2 w-[4px] h-[105%] -ml-[2px] bg-[#a72626] z-30 shadow-[3px_3px_5px_rgba(0,0,0,0.7)] origin-top transform rotate-[-2deg]">
      <!-- Tassel -->
      <div class="absolute bottom-[-15px] left-[-4px] w-[12px] h-[15px] bg-[#a72626]"></div>
      <div class="absolute bottom-[-22px] left-[-3px] w-[10px] h-[7px] bg-[#6e1313]"></div>
    </div>

    <!-- Left Cover Label (Ancient Pirate Aesthetic) -->
    <div class="w-full justify-center items-center md:w-1/2 h-full border-b-[3px] md:border-b-0 md:border-r-[3px] border-[#1f0d04] p-8 md:p-16 relative flex flex-col overflow-hidden">
      
      <!-- Parchment Background for Left Page -->
      <div class="absolute inset-4 md:inset-8 bg-[#e3cd98] rounded shadow-[inset_0_0_40px_rgba(80,50,20,0.5)] z-10 overflow-hidden">
        <svg class="absolute inset-0 w-full h-full opacity-30 pointer-events-none" xmlns="http://www.w3.org/2000/svg">
          <filter id="parchmentNoise">
            <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="4" />
          </filter>
          <rect width="100%" height="100%" filter="url(#parchmentNoise)" />
        </svg>
        
        <!-- Pirate Compass SVG Graphic -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-20 pointer-events-none">
          <svg width="250" height="250" viewBox="0 0 100 100" fill="none" stroke="#2a1608" stroke-width="2">
            <circle cx="50" cy="50" r="45" stroke-dasharray="2 4" />
            <circle cx="50" cy="50" r="35" stroke-width="1" />
            <path d="M50 5 L60 40 L95 50 L60 60 L50 95 L40 60 L5 50 L40 40 Z" fill="#2a1608" fill-opacity="0.3" stroke-width="1"/>
            <path d="M50 5 L50 95 M5 50 L95 50" stroke-width="1" />
            <circle cx="50" cy="50" r="5" fill="#2a1608" />
          </svg>
        </div>

        <div class="relative w-full h-full flex flex-col justify-center items-center p-8 z-20 text-[#2a1608]">
          <div class="border-[2px] border-[#2a1608] p-2 mb-8">
            <div class="border-[1px] border-[#2a1608] p-6 text-center bg-[#f0dba4] shadow-md">
              <h2 class="font-serif text-sm uppercase tracking-[0.3em] font-bold mb-4 border-b-2 border-[#2a1608] pb-2">Captain's Log</h2>
              <div class="font-serif text-5xl italic mb-2 tracking-wide font-black" style="text-shadow: 1px 1px 0px rgba(255,255,255,0.5);">Life Gallery</div>
              <div class="font-sans text-[11px] tracking-widest font-bold uppercase mt-6 relative inline-block">
                <span class="absolute top-1/2 left-[-20px] w-4 h-[1px] bg-[#2a1608]"></span>
                Here Be Dragons
                <span class="absolute top-1/2 right-[-20px] w-4 h-[1px] bg-[#2a1608]"></span>
              </div>
            </div>
          </div>
          
          <div class="absolute bottom-10 flex gap-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2a1608" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2a1608" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2a1608" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Page (Content area) -->
    <div class="w-full md:w-1/2 h-full p-8 md:p-16 relative overflow-y-auto custom-scrollbar-pirate z-10">
      
      <!-- Parchment Background for Right Page -->
      <div class="absolute inset-4 md:inset-8 md:ml-2 bg-[#e3cd98] rounded shadow-[inset_0_0_40px_rgba(80,50,20,0.5)] z-0 overflow-hidden pointer-events-none">
        <svg class="absolute inset-0 w-full h-full opacity-30" xmlns="http://www.w3.org/2000/svg">
          <filter id="parchmentNoiseRight">
            <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="3" />
          </filter>
          <rect width="100%" height="100%" filter="url(#parchmentNoiseRight)" />
        </svg>
        <!-- Faded treasure map lines -->
        <svg width="100%" height="100%" class="absolute inset-0 opacity-10" stroke="#2a1608" stroke-width="2" stroke-linecap="round" stroke-dasharray="10 15">
          <path d="M 50 100 Q 150 150 200 50 T 350 200" fill="none" />
          <path d="M 100 300 Q 250 250 300 400 T 450 300" fill="none" />
        </svg>
      </div>
      
      <div class="relative z-10 pt-8 px-4 md:px-8 text-[#2a1608]">
        <h1 class="font-serif text-4xl mb-10 font-bold border-b-2 border-dashed border-[#57351c] pb-4 flex items-center justify-between">
          <span>Stolen Memories</span>
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" class="opacity-50" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </h1>
        
        <div class="space-y-12">
          <!-- Gallery Item 1 -->
          <div class="relative pl-6 border-l-2 border-[#57351c]">
            <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-[#57351c] flex items-center justify-center">
              <div class="w-1.5 h-1.5 rounded-full bg-[#e3cd98]"></div>
            </div>
            <h3 class="font-serif text-2xl font-bold mb-2">The Hidden Cove</h3>
            <div class="w-full h-40 bg-[#c2a970] rounded border border-[#57351c] shadow-inner mb-4 flex items-center justify-center relative overflow-hidden group">
               <svg class="w-12 h-12 opacity-20 group-hover:scale-110 transition-transform duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
               <span class="absolute bottom-2 right-2 text-xs font-serif font-bold opacity-30">IMAGE_NOT_FOUND</span>
            </div>
            <p class="font-sans text-sm leading-relaxed">
              We dropped anchor near the jagged rocks at dawn. The water was unnervingly clear, revealing the rusted remains of those who sailed before us. A true treasure for the eyes.
            </p>
          </div>

          <!-- Gallery Item 2 -->
          <div class="relative pl-6 border-l-2 border-[#57351c]">
            <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-[#57351c] flex items-center justify-center">
              <div class="w-1.5 h-1.5 rounded-full bg-[#e3cd98]"></div>
            </div>
            <h3 class="font-serif text-2xl font-bold mb-2">Midnight Expo</h3>
            <div class="w-full h-40 bg-[#c2a970] rounded border border-[#57351c] shadow-inner mb-4 flex items-center justify-center relative overflow-hidden group">
               <svg class="w-12 h-12 opacity-20 group-hover:scale-110 transition-transform duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
               <span class="absolute bottom-2 right-2 text-xs font-serif font-bold opacity-30">ENGRAVING_LOST</span>
            </div>
            <p class="font-sans text-sm leading-relaxed">
              That day was hot hot burning hot. The structures are truly amazing. We navigated the burning sands to witness architecture that defied the laws of the very seas we sail.
            </p>
          </div>

        </div>

        <div class="mt-16 text-center text-[#57351c] font-serif italic text-lg tracking-wider border-t border-[rgba(42,22,8,0.2)] pt-6">
          "Dead Men Tell No Tales"
        </div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-6 text-[#8a684b] text-xs font-sans tracking-[0.3em] uppercase opacity-60">
    Property of Captain Fang
  </div>

</div>

<style>
  .custom-scrollbar-pirate::-webkit-scrollbar {
    width: 8px;
  }
  .custom-scrollbar-pirate::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar-pirate::-webkit-scrollbar-thumb {
    background: #57351c;
    border-radius: 4px;
    border: 2px solid #e3cd98;
  }
  .custom-scrollbar-pirate::-webkit-scrollbar-thumb:hover {
    background: #2a1608;
  }
</style>
